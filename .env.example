# ConfigVault environment configuration
# Copy to .env and fill in real values. NEVER commit .env.

# Secret used for API token auth (Bearer token). Generate a strong random value.
SECRET_KEY=change-me-to-a-long-random-string

# Database URI. Default is a local SQLite file under the Flask instance folder.
DATABASE_URL=sqlite:///configvault.db

# Device transport / integration toggles (optional overrides)
FTP_ENABLED=true
SFTP_ENABLED=true
TFTP_ENABLED=true
OXIDIZED_ENABLED=true
GIT_ENABLED=true
CLOUD_SYNC=false
